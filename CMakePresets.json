{
  "version": 6,
  "configurePresets": [
    {
      "name": "dev-ninja",
      "displayName": "Dev (Ninja, Debug)",
      "generator": "Ninja",
      "binaryDir": "build-ninja",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "VIX_KV_BUILD_TESTS": "ON"
      }
    },
    {
      "name": "release-ninja",
      "displayName": "Release (Ninja)",
      "generator": "Ninja",
      "binaryDir": "build-ninja-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "VIX_KV_BUILD_TESTS": "OFF"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "dev-ninja",
      "displayName": "Build (Dev, Ninja)",
      "configurePreset": "dev-ninja"
    },
    {
      "name": "release-ninja",
      "displayName": "Build (Release, Ninja)",
      "configurePreset": "release-ninja"
    }
  ],
  "testPresets": [
    {
      "name": "dev-ninja",
      "configurePreset": "dev-ninja",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
